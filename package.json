{
  "name": "cs130-final-project-2",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "build": "npm run build:server && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "npm run typecheck",
    "start:server": "node dist-server/index.js"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@dimforge/rapier2d-compat": "^0.19.3",
    "rollback-netcode": "^0.0.6",
    "three": "^0.184.0",
    "ws": "^8.20.0"
  }
}
