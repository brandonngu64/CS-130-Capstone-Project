# Copy this file to `.env` (same directory) and fill in your values.
#   cp setupScripts/.env.example setupScripts/.env
#   chmod 600 setupScripts/.env
# `.env` is gitignored so your No-IP credentials never get committed.

# No-IP hostname you created on the free tier, e.g. yourgame.ddns.net
DOMAIN=yourgame.ddns.net

# Email used by Let's Encrypt / Certbot for renewal + expiry notices
EMAIL=you@example.com

# Internal port the Node game/signaling server listens on.
# Matches the default in src/server/index.ts (SIGNALING_PORT ?? PORT ?? 3000).
GAME_PORT=3000

# --- No-IP Dynamic Update Client (DUC) credentials ---
# Recommended: in the No-IP dashboard create a "DDNS Key"
#   (Dynamic DNS > No-IP DDNS Keys) and use its username/password below.
# You can also use your No-IP account username/password, but a DDNS Key is safer.
NOIP_USERNAME=your-ddns-key-username
NOIP_PASSWORD=your-ddns-key-password

# The hostname the DUC keeps updated is your DOMAIN above — no extra var needed.
